# Review Desk — copy to `.env` (gitignored) and fill with real values.
# NEVER commit `.env`. The desk reads these at runtime; secrets stay server-side.

# Browser → desk login gate.
DESK_PASSPHRASE=change-me

# Shared secret between maw and the desk (Bearer, server-to-server). Generate with
# `openssl rand -base64 32` and set the SAME value on both the maw and desk containers.
MAW_REVIEW_DESK_SECRET=change-me

# maw review-plane base URL. In the e2e compose this is the maw service on the
# shared `review-desk-net` network: http://maw:3456 (patchwork's review-plane).
MAW_BASE_URL=http://maw:3456
